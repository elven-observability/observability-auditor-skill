{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elven-observability.github.io/observability-auditor-skill/schemas/findings.schema.json",
  "title": "Observability Audit Findings",
  "description": "Structured output of an audit run. Consumed by render_report.mjs.",
  "type": "object",
  "required": ["client", "timezone", "summary", "findings"],
  "additionalProperties": true,
  "properties": {
    "audit_id": { "type": "string" },
    "client": { "type": "string", "minLength": 1 },
    "org_id": { "oneOf": [{ "type": "string" }, { "type": "integer" }] },
    "timezone": { "type": "string", "minLength": 1 },
    "time_range": { "$ref": "#/$defs/window" },
    "operation_mode": { "type": "string", "enum": ["read_only", "write_requested", "restricted"] },
    "context_ref": { "type": "string" },
    "leading_finding_id": { "type": "string" },
    "recovery_taxonomy": {
      "type": "string",
      "enum": ["traffic-drop", "dependency-relief", "app-restart", "deploy-or-rollback", "mitigation-action", "unknown", ""]
    },
    "summary": {
      "type": "object",
      "required": ["business_symptom", "leading_finding", "leading_confidence"],
      "properties": {
        "business_symptom": { "type": "string" },
        "leading_finding": { "type": "string" },
        "residual_risk": { "type": "string" },
        "leading_confidence": { "$ref": "#/$defs/confidence" },
        "top_actions": { "type": "array", "items": { "type": "string" }, "maxItems": 5 }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "service_health": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "service": { "type": "string" },
          "env": { "type": "string" },
          "rps_delta": {},
          "p95_delta": {},
          "err_pct_delta": {},
          "dep_risk": { "type": "string" },
          "infra_risk": { "type": "string" },
          "summary": { "type": "string" }
        }
      }
    },
    "alerts_scored": { "type": "array", "items": { "$ref": "#/$defs/scoredAlert" } },
    "dashboards_scored": { "type": "array", "items": { "$ref": "#/$defs/scoredDashboard" } },
    "blind_spots": { "type": "array", "items": { "type": "string" } },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "owner", "priority"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "owner": { "type": "string" },
          "expected_impact": { "type": "string" },
          "validation_query": { "type": "string" },
          "priority": { "$ref": "#/$defs/priority" }
        }
      }
    }
  },
  "$defs": {
    "window": {
      "type": "object",
      "properties": {
        "start": { "type": "string" },
        "end": { "type": "string" }
      }
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "priority": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
    "finding": {
      "type": "object",
      "required": ["id", "title", "confidence"],
      "properties": {
        "id": { "type": "string", "pattern": "^f-[a-z0-9-]+$" },
        "title": { "type": "string" },
        "severity": { "$ref": "#/$defs/severity" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "claim": { "type": "string" },
        "impact": { "type": "string" },
        "datasource": { "type": "string" },
        "tool_or_query": { "type": "string" },
        "time_range": { "$ref": "#/$defs/window" },
        "filters": { "type": "object" },
        "observed": {},
        "baseline_or_comparator": {},
        "interpretation": { "type": "string" },
        "counter_test": { "type": "string" },
        "next_validation": { "type": "string" },
        "recommendation": { "type": "string" },
        "owner": { "type": "string" },
        "deeplinks": { "type": "array", "items": { "type": "string" } },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["metrics", "logs", "traces", "infra", "business", "root-cause", "appendix", "label-drift", "coverage-gap"]
          }
        },
        "timeline_rows": { "type": "array", "items": { "type": "object" } }
      }
    },
    "scoredAlert": {
      "type": "object",
      "required": ["title", "score"],
      "properties": {
        "uid": { "type": ["string", "null"] },
        "title": { "type": "string" },
        "service": { "type": "string" },
        "env": { "type": "string" },
        "severity": { "type": "string" },
        "alert_type": { "type": "string", "enum": ["symptom", "cause", "telemetry", "business", ""] },
        "current_threshold": {},
        "observed": { "type": "string" },
        "lead_time": { "type": "string" },
        "issue": { "type": "string" },
        "recommendation": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 5 },
        "priority": { "$ref": "#/$defs/priority" }
      }
    },
    "scoredDashboard": {
      "type": "object",
      "required": ["title", "score"],
      "properties": {
        "uid": { "type": ["string", "null"] },
        "title": { "type": "string" },
        "primary_question": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 5 },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "gaps": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "recommended_edits": { "type": "string" },
        "priority": { "$ref": "#/$defs/priority" }
      }
    }
  }
}
